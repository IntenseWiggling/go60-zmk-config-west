{
        "version": "0.2.0",
        "configurations": [
            {
            "type": "probe-rs-debug",
            "request": "launch",
            "name": "probe_rs rtt-target example",
            "cwd": "${workspaceFolder}",
            "chip": "nRF52840_xxAA",
            "flashingConfig": {
                "flashingEnabled": true,
                "verifyBeforeFlashing": true,
                "verifyAfterFlashing": true,
                "haltAfterReset": true
            },
            "coreConfigs": [
                {
                    "coreIndex": 0,
                    "programBinary": "./zmk.elf",
                    "rttEnabled": true,
                    "rttChannelFormats": [
                        {
                        "channelNumber": 0,
                        // Format RTT data as String data
                        "dataFormat": "String",
                        // Include host-side timestamps for every line of data transferred from the target RTT output
                        "showTimestamps": true
                        },
                        {
                        "channelNumber": 1,
                        // Treat data as raw binary data, and do not format in any way
                        "dataFormat": "BinaryLE"
                        }
                }
            ]
        }
    ]
}